{
  "name": "testsmith",
  "version": "0.1.0",
  "description": "CLI that ranks source files by test-risk and generates Vitest+RTL tests via the Claude Agent SDK",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "testsmith": "./dist/cli/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli/cli.ts",
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint src",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "commander": "^12.0.0",
    "dependency-cruiser": "^16.0.0",
    "ink": "^5.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "simple-git": "^3.0.0",
    "ts-morph": "^23.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
